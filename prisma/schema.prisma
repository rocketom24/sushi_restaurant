generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id    
  name      String
  email     String
  role      UserRole  @default(CUSTOMER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  orders    Order[]
  addresses CustomerAddress[]

  couponRedemptions CouponRedemption[]
  loyaltyAccount    LoyaltyAccount?
  rewardRedemptions RewardRedemption[]

  assignedKitchenTickets     KitchenTicket[]
  assignedKitchenTicketItems KitchenTicketItem[] @relation("KitchenTicketItemChef")

  @@index([email])
  @@index([role])
  @@map("users")
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String
  description String?
  imageUrl    String?
  iconName    String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  parentId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  parent      Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryToCategory")
  menuItems   MenuItem[]

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model MenuItem {
  id              String      @id @default(uuid())
  name            String
  description     String?
  price           Decimal     @db.Decimal(10, 2)
  imageUrl        String?
  preparationTime Int?
  isAvailable     Boolean     @default(true)
  categoryId      String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  category        Category    @relation(fields: [categoryId], references: [id])
  orderItems      OrderItem[]
  customizationGroups CustomizationGroup[]
  linkedByOptions     CustomizationOption[] @relation("OptionLinkedMenuItem")
  isFeatured Boolean     @default(false)
  sortOrder  Int         @default(0)
  calories   Int?
  spiceLevel SpiceLevel?


  @@index([categoryId])
  @@index([isAvailable])
  @@index([deletedAt, categoryId])
  @@index([isFeatured])
  @@map("menu_items")
}

model Table {
  id          String      @id @default(uuid())
  tableNumber Int         @unique
  capacity    Int
  qrToken     String      @unique
  status      TableStatus @default(AVAILABLE)
  notes       String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  orders      Order[]
  reservations Reservation[]

  @@index([tableNumber])
  @@index([qrToken])
  @@index([status])
  @@index([isActive])
  @@map("tables")
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  orderType       OrderType
  status          OrderStatus @default(NEW)
  userId          String?
  tableId         String?
  deliveryAddress String?
  subtotal        Decimal     @db.Decimal(10, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(10, 2)
  taxAmount       Decimal     @default(0) @db.Decimal(10, 2)
  serviceCharge   Decimal     @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal     @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  orderItems      OrderItem[]
  table           Table?      @relation(fields: [tableId], references: [id])
  user            User?       @relation(fields: [userId], references: [id])
  payments        Payment[]

  discountId String?
  discount   Discount? @relation(fields: [discountId], references: [id], onDelete: SetNull)

  couponRedemptions   CouponRedemption[]
  loyaltyTransactions LoyaltyTransaction[]

  
  kitchenTicket KitchenTicket?


  @@index([status])
  @@index([orderType])
  @@index([tableId])
  @@index([createdAt])
  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id         String    @id @default(uuid())
  quantity   Int       @default(1)
  unitPrice  Decimal   @db.Decimal(10, 2)
  subtotal   Decimal   @db.Decimal(10, 2)
  notes      String?
  orderId    String
  menuItemId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  menuItem   MenuItem  @relation(fields: [menuItemId], references: [id])
  order      Order     @relation(fields: [orderId], references: [id])
  customizations OrderItemCustomization[]
  kitchenTicketItem KitchenTicketItem?

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

// Updated Payment model
model Payment {
  id String @id @default(uuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  method    PaymentMethod
  cardBrand CardBrand?
  gateway   PaymentGateway
  status    PaymentStatus @default(PENDING)

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("EUR")

  transactionId    String?
  gatewayReference String?

  paidAt       DateTime?
  refundedAt   DateTime?
  refundAmount Decimal?  @db.Decimal(10, 2)
  failureReason String?

  notes String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([orderId])
  @@index([status])
  @@index([method])
  @@index([paidAt])
  @@map("payments")
}



model Reservation {
  id String @id @default(uuid())

  customerName String
  phone        String
  email        String?
  guestCount   Int

  reservationAt DateTime
  status        ReservationStatus @default(PENDING)
  source        ReservationSource

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  specialRequest String?
  internalNote   String?

  arrivedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([reservationAt])
  @@index([tableId])
  @@index([phone])
  @@map("reservations")
}

model CustomizationGroup {
  id   String @id @default(uuid())
  name String // e.g. "Portion", "Spice Level", "Sauce"

  isRequired    Boolean       @default(false)
  selectionType SelectionType @default(SINGLE)
  sortOrder     Int           @default(0)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  options CustomizationOption[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([menuItemId])
  @@map("customization_groups")
}

model CustomizationOption {
  id   String @id @default(uuid())
  name String // e.g. "6 Pieces", "Spicy Mayo", "Extra Nigiri"

  // Additive cost for this choice — 0 for most, positive for upsells
  // like "Extra Avocado" or "Extra Gyoza"
  priceModifier Decimal @default(0) @db.Decimal(10, 2)
  sortOrder     Int     @default(0)

  groupId String
  group   CustomizationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // An option may reference another MenuItem — e.g. "Extra Nigiri" in a
  // Combo Box points at the actual Nigiri MenuItem for pricing/kitchen prep
  linkedMenuItemId String?
  linkedMenuItem   MenuItem? @relation("OptionLinkedMenuItem", fields: [linkedMenuItemId], references: [id], onDelete: SetNull)

   orderItemCustomizations OrderItemCustomization[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([groupId])
  @@index([linkedMenuItemId])
  @@map("customization_options")
}

model OrderItemCustomization {
  id String @id @default(uuid())

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  // Nullable, non-restrictive reference back to the source option —
  // useful for analytics ("how often is Spicy Mayo picked") but never
  // relied on for display, since the option itself may be edited/deleted later
  optionId String?
  option   CustomizationOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  // Snapshot fields — the actual source of truth for receipts/kitchen tickets.
  // Menu changes must never alter historical orders (per business rules).
  groupName     String
  optionName    String
  priceModifier Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([orderItemId])
  @@index([optionId])
  @@map("order_item_customizations")
}

model CustomerAddress {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label       String  // e.g. "Home", "Office", "Parents"
  fullAddress String
  city        String?
  postalCode  String?
  notes       String? // e.g. gate code, floor number — freeform for now

  isDefault Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([userId, isDefault])
  @@map("customer_addresses")
}



model Discount {
  id          String       @id @default(uuid())
  name        String
  description String?
  type        DiscountType
  value       Decimal      @db.Decimal(10, 2)

  isActive Boolean   @default(true)
  startsAt DateTime?
  endsAt   DateTime?

  // Traceability only — the actual charged amount is already snapshotted
  // on Order.discountAmount. This just tells you *which* automatic
  // discount produced it, for reporting.
  orders Order[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([isActive])
  @@map("discounts")
}

// =======================================================
// COUPON — applied using a code (e.g. WELCOME10)
// =======================================================

model Coupon {
  id          String       @id @default(uuid())
  code        String
  description String?
  type        DiscountType
  value       Decimal      @db.Decimal(10, 2)

  minOrderAmount  Decimal? @db.Decimal(10, 2)
  maxUsageCount   Int? // total redemptions allowed across all customers, null = unlimited
  maxUsagePerUser Int? // null = unlimited per customer
  usageCount      Int      @default(0)

  isActive Boolean   @default(true)
  startsAt DateTime?
  endsAt   DateTime?

  redemptions CouponRedemption[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Not @unique on code — same soft-delete reasoning used throughout.
  // Enforce uniqueness among active rows at the application layer:
  // WHERE code = ? AND deletedAt IS NULL
  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

// Permanent audit record of a coupon being used on an order.
// No soft delete — this is an immutable ledger entry, not an editable resource.
model CouponRedemption {
  id String @id @default(uuid())

  couponId String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Restrict)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Restrict)

  // Optional — guest checkout has no user account
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Snapshot of the discount actually applied, independent of later
  // changes to Coupon.value
  discountAmount Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([couponId])
  @@index([orderId])
  @@index([userId])
  @@map("coupon_redemptions")
}

// =======================================================
// LOYALTY — customers earn points from purchases
// =======================================================

model LoyaltyAccount {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  pointsBalance Int @default(0)

  transactions LoyaltyTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("loyalty_accounts")
}

// Permanent ledger — "Transactions are stored permanently" per the doc.
// No soft delete, no updatedAt — each row is a fixed historical fact.
model LoyaltyTransaction {
  id String @id @default(uuid())

  loyaltyAccountId String
  loyaltyAccount   LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id], onDelete: Restrict)

  // Optional — points can be earned from an order, or adjusted manually
  // by staff (correction, goodwill gesture) with no order involved
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  type        LoyaltyTransactionType
  points      Int // positive for EARNED, negative for REDEEMED/EXPIRED
  description String?
  rewardRedemption RewardRedemption?

  createdAt DateTime @default(now())

  @@index([loyaltyAccountId])
  @@index([orderId])
  @@index([type])
  @@map("loyalty_transactions")
}

// =======================================================
// REWARDS — restaurant-defined items redeemable with points
// =======================================================

model Reward {
  id          String  @id @default(uuid())
  name        String
  description String?
  pointsCost  Int
  isActive    Boolean @default(true)

  redemptions RewardRedemption[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([isActive])
  @@map("rewards")
}

// Permanent record of a reward being claimed. No soft delete —
// same immutable-ledger reasoning as CouponRedemption.
model RewardRedemption {
  id String @id @default(uuid())

  rewardId String
  reward   Reward @relation(fields: [rewardId], references: [id], onDelete: Restrict)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  // Links to the ledger entry that deducted the points, so the
  // point deduction and the reward claim stay traceable to each other
  loyaltyTransactionId String?             @unique
  loyaltyTransaction   LoyaltyTransaction? @relation(fields: [loyaltyTransactionId], references: [id], onDelete: SetNull)

  fulfilled  Boolean   @default(false)
  redeemedAt DateTime  @default(now())
  fulfilledAt DateTime?

  @@index([rewardId])
  @@index([userId])
  @@map("reward_redemptions")
}



model KitchenTicket {
  id String @id @default(uuid())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status KitchenTicketStatus @default(QUEUED)

  // Chef currently responsible for this ticket overall.
  // Nullable — a ticket can sit in queue before anyone picks it up.
  assignedChefId String?
  assignedChef   User?   @relation(fields: [assignedChefId], references: [id], onDelete: SetNull)

  // Timing — supports "Order timing" and future kitchen analytics
  queuedAt    DateTime  @default(now())
  startedAt   DateTime?
  readyAt     DateTime?
  servedAt    DateTime?

  notes String?

  items KitchenTicketItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([assignedChefId])
  @@index([queuedAt])
  @@map("kitchen_tickets")
}

// =======================================================
// KITCHEN TICKET ITEM — per-item prep tracking within a ticket.
// Individual dishes finish at different times (nigiri is fast,
// a combo box is slow) so status is tracked per item, not just
// per whole order.
// =======================================================

model KitchenTicketItem {
  id String @id @default(uuid())

  kitchenTicketId String
  kitchenTicket   KitchenTicket @relation(fields: [kitchenTicketId], references: [id], onDelete: Cascade)

  orderItemId String    @unique
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  status KitchenTicketStatus @default(QUEUED)

  // Optional — supports future "multiple chefs" without redesigning now;
  // individual dishes can be assigned separately from the ticket's main chef
  assignedChefId String?
  assignedChef   User?   @relation("KitchenTicketItemChef", fields: [assignedChefId], references: [id], onDelete: SetNull)

  startedAt DateTime?
  readyAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kitchenTicketId])
  @@index([status])
  @@index([assignedChefId])
  @@map("kitchen_ticket_items")
}





enum UserRole {
  OWNER
  KITCHEN
  CUSTOMER
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ReservationSource {
  ONLINE
  PHONE
  WALK_IN
}

enum PaymentMethod {
  CASH
  CARD
  SATISPAY
  TICKET_RESTAURANT_EDENRED
}

enum CardBrand {
  VISA
  MASTERCARD
  AMERICAN_EXPRESS
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentGateway {
  NONE
  SATISPAY
  STRIPE
  EDENRED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum SelectionType {
  SINGLE
  MULTIPLE
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum LoyaltyTransactionType {
  EARNED
  REDEEMED
  ADJUSTED
  EXPIRED
}

enum KitchenTicketStatus {
  QUEUED
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum SpiceLevel {
  NONE
  MILD
  MEDIUM
  HOT
}