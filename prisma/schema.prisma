generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String
  password  String
  role      UserRole  @default(CUSTOMER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  orders    Order[]
  addresses CustomerAddress[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String
  description String?
  imageUrl    String?
  iconName    String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  parentId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  parent      Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryToCategory")
  menuItems   MenuItem[]

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model MenuItem {
  id              String      @id @default(uuid())
  name            String
  description     String?
  price           Decimal     @db.Decimal(10, 2)
  imageUrl        String?
  preparationTime Int?
  isAvailable     Boolean     @default(true)
  categoryId      String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  category        Category    @relation(fields: [categoryId], references: [id])
  orderItems      OrderItem[]
  customizationGroups CustomizationGroup[]
  linkedByOptions     CustomizationOption[] @relation("OptionLinkedMenuItem")


  @@index([categoryId])
  @@index([isAvailable])
  @@index([deletedAt, categoryId])
  @@map("menu_items")
}

model Table {
  id          String      @id @default(uuid())
  tableNumber Int         @unique
  capacity    Int
  qrToken     String      @unique
  status      TableStatus @default(AVAILABLE)
  notes       String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  orders      Order[]
  reservations Reservation[]

  @@index([tableNumber])
  @@index([qrToken])
  @@index([status])
  @@index([isActive])
  @@map("tables")
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  orderType       OrderType
  status          OrderStatus @default(NEW)
  userId          String?
  tableId         String?
  deliveryAddress String?
  subtotal        Decimal     @db.Decimal(10, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(10, 2)
  taxAmount       Decimal     @default(0) @db.Decimal(10, 2)
  serviceCharge   Decimal     @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal     @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  orderItems      OrderItem[]
  table           Table?      @relation(fields: [tableId], references: [id])
  user            User?       @relation(fields: [userId], references: [id])
  payments        Payment[]

  @@index([status])
  @@index([orderType])
  @@index([tableId])
  @@index([createdAt])
  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id         String    @id @default(uuid())
  quantity   Int       @default(1)
  unitPrice  Decimal   @db.Decimal(10, 2)
  subtotal   Decimal   @db.Decimal(10, 2)
  notes      String?
  orderId    String
  menuItemId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  menuItem   MenuItem  @relation(fields: [menuItemId], references: [id])
  order      Order     @relation(fields: [orderId], references: [id])
  customizations OrderItemCustomization[]

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

model Payment {
  id            String         @id @default(uuid())
  orderId       String
  cardBrand     CardBrand?
  method        PaymentMethod
  gateway       PaymentGateway
  status        PaymentStatus  @default(PENDING)
  amount        Decimal        @db.Decimal(10, 2)
  currency      String         @default("EUR")
  transactionId String?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  order         Order          @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([method])
  @@index([paidAt])
  @@map("payments")
}

model Reservation {
  id String @id @default(uuid())

  customerName String
  phone        String
  email        String?
  guestCount   Int

  reservationAt DateTime
  status        ReservationStatus @default(PENDING)
  source        ReservationSource

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  specialRequest String?
  internalNote   String?

  arrivedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([reservationAt])
  @@index([tableId])
  @@index([phone])
  @@map("reservations")
}

model CustomizationGroup {
  id   String @id @default(uuid())
  name String // e.g. "Portion", "Spice Level", "Sauce"

  isRequired    Boolean       @default(false)
  selectionType SelectionType @default(SINGLE)
  sortOrder     Int           @default(0)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  options CustomizationOption[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([menuItemId])
  @@map("customization_groups")
}

model CustomizationOption {
  id   String @id @default(uuid())
  name String // e.g. "6 Pieces", "Spicy Mayo", "Extra Nigiri"

  // Additive cost for this choice — 0 for most, positive for upsells
  // like "Extra Avocado" or "Extra Gyoza"
  priceModifier Decimal @default(0) @db.Decimal(10, 2)
  sortOrder     Int     @default(0)

  groupId String
  group   CustomizationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // An option may reference another MenuItem — e.g. "Extra Nigiri" in a
  // Combo Box points at the actual Nigiri MenuItem for pricing/kitchen prep
  linkedMenuItemId String?
  linkedMenuItem   MenuItem? @relation("OptionLinkedMenuItem", fields: [linkedMenuItemId], references: [id], onDelete: SetNull)

   orderItemCustomizations OrderItemCustomization[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([groupId])
  @@index([linkedMenuItemId])
  @@map("customization_options")
}

model OrderItemCustomization {
  id String @id @default(uuid())

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  // Nullable, non-restrictive reference back to the source option —
  // useful for analytics ("how often is Spicy Mayo picked") but never
  // relied on for display, since the option itself may be edited/deleted later
  optionId String?
  option   CustomizationOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  // Snapshot fields — the actual source of truth for receipts/kitchen tickets.
  // Menu changes must never alter historical orders (per business rules).
  groupName     String
  optionName    String
  priceModifier Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([orderItemId])
  @@index([optionId])
  @@map("order_item_customizations")
}

model CustomerAddress {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label       String  // e.g. "Home", "Office", "Parents"
  fullAddress String
  city        String?
  postalCode  String?
  notes       String? // e.g. gate code, floor number — freeform for now

  isDefault Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([userId, isDefault])
  @@map("customer_addresses")
}



enum UserRole {
  OWNER
  KITCHEN
  CUSTOMER
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ReservationSource {
  ONLINE
  PHONE
  WALK_IN
}

enum PaymentMethod {
  CASH
  CARD
  SATISPAY
  TICKET_RESTAURANT_EDENRED
}

enum CardBrand {
  VISA
  MASTERCARD
  AMERICAN_EXPRESS
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentGateway {
  MANUAL
  STRIPE
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum SelectionType {
  SINGLE
  MULTIPLE
}